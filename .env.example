SLACK_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=C0123456789
SLACK_TEXT=Workflow engine canlı test 🚀

APP_URL=http://localhost:5173
NATS_URL=nats://localhost:4222

# --- LLM provider (agent + chat model) ---
# google (default; our managed deploy keeps using this), openai, anthropic,
# or local / openai-compatible for a local server (Ollama, LM Studio, vLLM).
# Leave LLM_PROVIDER empty to use google.
LLM_PROVIDER=
LLM_MODEL=
LLM_BASE_URL=                       # local/openai-compatible, e.g. http://localhost:11434/v1
LLM_API_KEY=                        # openai/anthropic key (local servers ignore it)
# google provider reads these:
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Self-host single-user mode: skip the login screen, act as one "local" user.
# 1 = no auth (default for local self-host). Set 0 + configure auth if exposed.
DISABLE_AUTH=1

# Official hosted service (mergn.app). Shows Terms of Service and Privacy Policy.
# Auto-enabled when DISABLE_AUTH=0 (production). Set MANAGED=0 to hide on a
# self-hosted instance that runs with auth. Set MANAGED=1 to force show.
# MANAGED=1

BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

STORE_DRIVER=file
MONGO_URL=mongodb://localhost:27017
MONGO_DB=workflow

# Code execution for workflow steps:
#   (empty) in-process — dev only, refused in production
#   docker  run each step in a sibling container on the host (self-host default)
#   remote  external sandbox service (CODE_EXEC_URL)
CODE_RUNTIME=docker
DOCKER_IMAGE=node:22-slim
CODE_TIMEOUT_SEC=30
# DooD — only when the APP itself runs in a container (e.g. docker compose):
# mount /var/run/docker.sock + a shared named volume, then set these.
# Leave empty when running the app directly on the host.
DOCKER_WORK_DIR=
DOCKER_VOLUME=
# remote sandbox (CODE_RUNTIME=remote):
CODE_EXEC_URL=http://localhost:5070
CODE_EXEC_TOKEN=

# WHERE secrets/credentials are stored: doc (mongo) or s3.
VAULT_DRIVER=doc
S3_BUCKET=workflow-secrets
S3_REGION=auto
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# ─── LIMITS (knobs defined in src/limits.ts) ─────────────────────────────────
# Limits are OFF by default — self-host runs UNCAPPED. A hosted deployment turns
# them on with ENFORCE_LIMITS=1 and sets the numbers it wants in its OWN env
# (e.g. compose), never in source. Any var left unset = no cap for that limit.
# Set ENFORCE_LIMITS=1 to enforce, then assign any of the following:
#
#   ENFORCE_LIMITS                 master switch (1 = enforce)
#   FREE_CHAT_LIMIT                Free plan: chats / month
#   FREE_TOKEN_LIMIT               Free plan: AI tokens / month
#   PRO_TOKEN_LIMIT                Pro plan:  AI tokens / month
#   CHAT_USER_LIMIT_PER_MIN        chat prompts / min, per user
#   CHAT_GLOBAL_LIMIT_PER_MIN      chat prompts / min, all users combined
#   LLM_DIRECT_LIMIT_PER_MIN       repair/probe calls / min, per user
#   HOOK_LIMIT_PER_MIN             inbound webhook calls / min
#   PROMPT_TOKEN_CAP               max tokens one chat prompt may spend
#   MAX_OUTPUT_TOKENS              max output tokens PER model call (chat + every
#                                  internal authoring call) — the main cost lever
#                                  (output is ~6x input). Unset = model default.
#   GLOBAL_TOKEN_CAP               deployment-wide token kill-switch (0 = off)
#   MAX_PLAN_STEPS                 max steps a single workflow build authors
#   MAX_SPACES_PER_USER            workspaces per account
#   MAX_STORAGE_BYTES              total uploaded-file storage per workspace

# Email (Resend) — for the sign-up email-verification code. When BOTH are set,
# new email/password signups must enter a 6-digit code emailed to them before
# using the app. Leave unset for self-host: no verification, instant signups.
# RESEND_API_KEY=re_...
# MAIL_ADDRESS="MergN <noreply@yourdomain.com>"
# APP_NAME=MergN

# Billing (Stripe). Leave unset for self-host: no plans/limits, no billing UI
# changes (everyone is on the local "free" plan, uncapped). Set these on the
# managed deployment to enable plans (Free/Pro/Enterprise) + the Stripe portal.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FREE=price_...   # $0 recurring price (auto-provisioned per space)
# STRIPE_PRICE_PRO=price_...    # $19/mo recurring price

# HOW secrets are encrypted at rest. Leave unset for self-host: secrets are
# stored as-is and NO extra service is needed. Set to "vault" to encrypt with a
# HashiCorp Vault Transit engine (the key never leaves Vault) — requires a Vault
# service and the three vars below. Intended for managed/prod deployments.
# SECRET_ENCRYPTION=vault
# VAULT_ADDRESS=http://vault:8200
# VAULT_TOKEN=
# VAULT_KEY_NAME=mergn

GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# --- AI chat app / MCP integration ---
# The Model Context Protocol endpoint at /mcp lets Claude Code, Claude.ai,
# ChatGPT or Gemini build and run your workflows. On self-host it is ON BY
# DEFAULT — no setting needed. Set to 0 to turn it OFF (e.g. an instance exposed
# to the internet). See the "Connect an AI chat app (MCP)" section in the README.
# ENABLE_REMOTE_MCP=0
