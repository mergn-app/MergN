#!/usr/bin/env bash
# MergN CLI - thin dispatcher so you can run `mergn update` from anywhere.
# Install once (see README):  sudo ln -sf "$PWD/mergn" /usr/local/bin/mergn
# (or, for the native/npm install:  npm link).
set -euo pipefail

# Resolve the repo dir even when invoked through a PATH symlink, so the
# subcommands always operate on the actual checkout.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
REPO="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
cd "$REPO"

usage() {
  cat <<EOF
MergN - self-host CLI  (repo: $REPO)

Usage: mergn <command>

  run [--update]     start the app - native: backend (:8787) + web (:5173)
                     together; Docker: docker compose up -d. Auto-detected.
                     Warns if an update exists; --update pulls it first.
  update [--build]   pull the latest version and apply it (Docker or native,
                     auto-detected). --build forces a local Docker build.
  logs               follow the app logs        (docker compose logs -f app)
  restart            restart the app            (docker compose restart app)
  status             show container status      (docker compose ps)
  down               stop the stack             (docker compose down)
  help               show this help
EOF
}

# Best-effort "you're behind" notice before starting - never blocks or applies
# anything (use `mergn update` to actually pull). Silent if offline / no git.
update_notice() {
  command -v git >/dev/null 2>&1 || return 0
  git rev-parse --git-dir >/dev/null 2>&1 || return 0
  if command -v timeout >/dev/null 2>&1; then
    timeout 5 git fetch -q origin 2>/dev/null || return 0
  else
    git fetch -q origin 2>/dev/null || return 0
  fi
  local head remote behind
  head=$(git rev-parse HEAD 2>/dev/null) || return 0
  remote=$(git rev-parse '@{u}' 2>/dev/null || git rev-parse origin/main 2>/dev/null) || return 0
  [ "$head" = "$remote" ] && return 0
  behind=$(git rev-list --count "HEAD..$remote" 2>/dev/null || echo 0)
  if [ "$behind" -gt 0 ] 2>/dev/null; then
    printf '\033[1m-> Update available (%s commit(s)). Run:  mergn update\033[0m\n' "$behind"
  fi
}

run_native() {
  echo "-> Starting MergN (native) - backend :8787 + web :5173. Ctrl+C to stop."
  npm run server &
  local back=$!
  ( cd web && npm run dev ) &
  local web=$!
  trap 'kill "$back" "$web" 2>/dev/null || true' INT TERM EXIT
  wait
}

cmd="${1:-help}"
[ $# -gt 0 ] && shift || true

case "$cmd" in
  run | start | dev)
    if [ "${1:-}" = "--update" ]; then
      ./update.sh           # pull & apply first (starts Docker; installs native)
    else
      update_notice || true # just warn if behind, then start
    fi
    if [ -d node_modules ] && [ -d web/node_modules ]; then
      run_native
    elif command -v docker >/dev/null 2>&1; then
      if ! docker info >/dev/null 2>&1; then
        echo "Docker is installed but not running. Start Docker Desktop, then 'mergn run'." >&2
        exit 1
      fi
      echo "-> Starting MergN (Docker)..."
      docker compose up -d
      echo "OK Up at http://localhost:8787 - logs:  mergn logs"
    else
      echo "Nothing to run yet. Either:" >&2
      echo "  - start Docker, then 'mergn run', or" >&2
      echo "  - install native deps:  npm install && (cd web && npm install)" >&2
      exit 1
    fi
    ;;
  update) exec ./update.sh "$@" ;;
  logs) exec docker compose logs -f app ;;
  restart) exec docker compose restart app ;;
  status) exec docker compose ps ;;
  down|stop) exec docker compose down ;;
  -h | --help | help) usage ;;
  *)
    echo "mergn: unknown command '$cmd'" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
