# Copy to .env and fill in. Generate secrets with the commands shown.
# .env in this folder is gitignored — never commit real secrets.

NEXTAUTH_URL=http://localhost:3000

# openssl rand -base64 32
NEXTAUTH_SECRET=
# openssl rand -base64 32
SALT=
# openssl rand -hex 32   (must be 64 hex chars)
ENCRYPTION_KEY=

# Postgres — DATABASE_URL password must match POSTGRES_PASSWORD
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/postgres

# ClickHouse
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=

# Redis
REDIS_AUTH=

# MinIO / S3 — the three S3 secret keys must equal MINIO_ROOT_PASSWORD
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=

# Auto-provision on first boot. Set PUBLIC/SECRET key to match the app's
# ../.env LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY.
LANGFUSE_INIT_ORG_ID=workflow
LANGFUSE_INIT_ORG_NAME=Workflow
LANGFUSE_INIT_PROJECT_ID=workflow-builder
LANGFUSE_INIT_PROJECT_NAME=Workflow Builder
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-...
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-...
LANGFUSE_INIT_USER_EMAIL=you@example.com
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=
